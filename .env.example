DATABASE_URL=postgres://mmorpg:mmorpg@localhost:5432/mmorpg?sslmode=disable
JWT_SECRET=change-me-in-production-use-a-long-random-string
PORT=8080

# Set MOCK_AI=true to skip Claude API calls and use stub data (no API key needed).
# Set to false and provide a real key when you're ready to use actual AI parsing.
MOCK_AI=true
ANTHROPIC_API_KEY=

# Local file storage for uploaded CVs
UPLOAD_DIR=./uploads

# GitHub OAuth — create an app at https://github.com/settings/developers
# Callback URL should be: http://localhost:8080/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/github/callback
FRONTEND_URL=http://localhost:5173
